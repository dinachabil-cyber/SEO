{% extends 'base.html.twig' %}

{% block title %}Sites{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">Sites</h1>

    {% for flashType, flashMessages in app.flashes %}
        {% for flashMessage in flashMessages %}
            <div class="alert alert-{{ flashType }} alert-dismissible fade show" role="alert">
                {{ flashMessage }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Filters Form -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="card-title mb-0">Filters</h5>
        </div>
        <div class="card-body">
            {{ form_start(filtersForm, { 'attr': { 'class': 'row g-3' } }) }}
            <div class="col-md-3">
                {{ form_label(filtersForm.creator) }}
                {{ form_widget(filtersForm.creator) }}
                {{ form_errors(filtersForm.creator) }}
            </div>
            <div class="col-md-3">
                {{ form_label(filtersForm.technology) }}
                {{ form_widget(filtersForm.technology) }}
                {{ form_errors(filtersForm.technology) }}
            </div>
            <div class="col-md-3">
                {{ form_label(filtersForm.hosting) }}
                {{ form_widget(filtersForm.hosting) }}
                {{ form_errors(filtersForm.hosting) }}
            </div>
            <div class="col-md-2">
                {{ form_label(filtersForm.status) }}
                {{ form_widget(filtersForm.status) }}
                {{ form_errors(filtersForm.status) }}
            </div>
            <div class="col-md-12">
                <div class="row g-3 align-items-end">
                    <div class="col-md-8">
                        {{ form_label(filtersForm.domain) }}
                        {{ form_widget(filtersForm.domain) }}
                        {{ form_errors(filtersForm.domain) }}
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Apply Filters
                        </button>
                    </div>
                </div>
            </div>
            {{ form_end(filtersForm) }}
        </div>
    </div>

    <!-- Sites Table -->
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">All Sites</h5>
                <a href="{{ path('app_site_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus"></i> Create New Site
                </a>
            </div>
        </div>
        <div class="card-body">
            {% if sites|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Domain</th>
                                <th>Locale</th>
                                <th>Hosting</th>
                                <th>Database</th>
                                <th>Technology</th>
                                <th>Published At</th>
                                <th>Creator</th>
                                <th>Pages</th>
                                <th>Imprint</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for site in sites %}
                                <tr>
                                    <td>
                                        {% if site.domain %}
                                            <a href="{{ site.domain }}" target="_blank">{{ site.domain }}</a>
                                        {% else %}
                                            <span class="text-muted">No domain</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.defaultLocale %}
                                            {{ site.defaultLocale }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.hosting %}
                                            {{ site.hosting }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.databaseName %}
                                            <span>{{ site.databaseName }} </span>
                                            <button type="button" class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#databaseCredentialsModal{{ site.id }}" title="Show database password">
                                                <i class="bi bi-key"></i>
                                            </button>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.technology %}
                                            {{ site.technology }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.publishedAt %}
                                            {{ site.publishedAt|format_datetime }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.user and site.user.name %}
                                            {{ site.user.name }}
                                        {% else %}
                                            <span class="text-muted">Unknown</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {{ site.pageCount }}
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#imprintModal{{ site.id }}">
                                            View Imprint
                                        </button>
                                    </td>
                                    <td>
                                        <span class="badge {{ site.statusBadgeClass }}">{{ site.status|default('Draft') }}</span>
                                    </td>
                                    <td>
                                        <a href="{{ path('app_site_show', {'id': site.id}) }}" class="btn btn-sm btn-primary" title="Manage">
                                            <i class="bi bi-gear"></i> Manage
                                        </a>
                                        <a href="{{ path('app_site_edit', {'id': site.id}) }}" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        {% if site.domain %}
                                            <a href="{{ site.domain }}" target="_blank" class="btn btn-sm btn-outline-success" title="Open Site">
                                                <i class="bi bi-box-arrow-up-right"></i> Open
                                            </a>
                                        {% endif %}
                                        <form method="POST" action="{{ path('app_site_delete', {'id': site.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this site?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ site.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <h5>No sites found</h5>
                    <p class="text-muted">Create your first site or adjust the filters above</p>
                    <a href="{{ path('app_site_new') }}" class="btn btn-primary mt-3">
                        <i class="bi bi-plus"></i> Create Site
                    </a>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Database Credentials Modals -->
    {% for site in sites %}
        <div class="modal fade" id="databaseCredentialsModal{{ site.id }}" tabindex="-1" aria-labelledby="databaseCredentialsModalLabel{{ site.id }}" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="databaseCredentialsModalLabel{{ site.id }}">Site Credentials</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        {% if app.user and site.user and app.user.id == site.user.id %}
                            <div class="mb-3">
                                <label class="form-label fw-bold">Database Name:</label>
                                <p>{{ site.databaseName }}</p>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Database Password:</label>
                                <div class="input-group">
                                    <input type="password" id="password{{ site.id }}" class="form-control" value="{{ site.databasePassword }}" readonly>
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('password{{ site.id }}', 'toggleBtn{{ site.id }}')" id="toggleBtn{{ site.id }}">Show</button>
                                    <button class="btn btn-outline-secondary" type="button" onclick="copyPassword('password{{ site.id }}')">Copy</button>
                                </div>
                            </div>
                        {% else %}
                            <div class="alert alert-warning" role="alert">
                                You do not have permission to view these credentials
                            </div>
                        {% endif %}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}

    <!-- Imprint Modals -->
    {% for site in sites %}
        <div class="modal fade" id="imprintModal{{ site.id }}" tabindex="-1" aria-labelledby="imprintModalLabel{{ site.id }}" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="imprintModalLabel{{ site.id }}">Imprint Information</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        {% if site.hasImprintData() %}
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Company Name:</label>
                                        <p>{{ site.companyName or '-' }}</p>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Address:</label>
                                        <p>{{ site.address or '-' }}</p>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Phone:</label>
                                        <p>{{ site.phone or '-' }}</p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Email:</label>
                                        <p>{{ site.email or '-' }}</p>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Legal Representative:</label>
                                        <p>{{ site.legalRepresentative or '-' }}</p>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Registration Number:</label>
                                        <p>{{ site.registrationNumber or '-' }}</p>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="alert alert-info" role="alert">
                                No imprint data available
                            </div>
                        {% endif %}
                    </div>
                    <div class="modal-footer">
                        <a href="{{ path('app_site_edit', {'id': site.id}) }}" class="btn btn-primary">Edit Imprint</a>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}

    <script>
        function togglePassword(passwordId, buttonId) {
            const passwordInput = document.getElementById(passwordId);
            const toggleButton = document.getElementById(buttonId);
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleButton.textContent = 'Hide';
            } else {
                passwordInput.type = 'password';
                toggleButton.textContent = 'Show';
            }
        }

        function copyPassword(passwordId) {
            const passwordInput = document.getElementById(passwordId);
            passwordInput.select();
            passwordInput.setSelectionRange(0, 99999); /* For mobile devices */
            
            navigator.clipboard.writeText(passwordInput.value).then(() => {
                const originalValue = passwordInput.value;
                passwordInput.value = 'Copied!';
                setTimeout(() => {
                    passwordInput.value = originalValue;
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy password:', err);
            });
        }
    </script>
</div>
{% endblock %}
