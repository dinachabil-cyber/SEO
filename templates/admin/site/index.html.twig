{% extends 'base.html.twig' %}

{% block title %}Sites{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">Sites</h1>

    {% for flashType, flashMessages in app.flashes %}
        {% for flashMessage in flashMessages %}
            <div class="alert alert-{{ flashType }} alert-dismissible fade show" role="alert">
                {{ flashMessage }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Filters Form -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="card-title mb-0">Filters</h5>
        </div>
        <div class="card-body">
            {{ form_start(filtersForm, { 'attr': { 'class': 'row g-3' } }) }}
            <div class="col-md-3">
                {{ form_label(filtersForm.creator) }}
                {{ form_widget(filtersForm.creator) }}
                {{ form_errors(filtersForm.creator) }}
            </div>
            <div class="col-md-3">
                {{ form_label(filtersForm.technology) }}
                {{ form_widget(filtersForm.technology) }}
                {{ form_errors(filtersForm.technology) }}
            </div>
            <div class="col-md-3">
                {{ form_label(filtersForm.hosting) }}
                {{ form_widget(filtersForm.hosting) }}
                {{ form_errors(filtersForm.hosting) }}
            </div>
            <div class="col-md-2">
                {{ form_label(filtersForm.status) }}
                {{ form_widget(filtersForm.status) }}
                {{ form_errors(filtersForm.status) }}
            </div>
            <div class="col-md-12">
                <div class="row g-3 align-items-end">
                    <div class="col-md-8">
                        {{ form_label(filtersForm.domain) }}
                        {{ form_widget(filtersForm.domain) }}
                        {{ form_errors(filtersForm.domain) }}
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Apply Filters
                        </button>
                    </div>
                </div>
            </div>
            {{ form_end(filtersForm) }}
        </div>
    </div>

    <!-- Sites Table -->
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">All Sites</h5>
                <a href="{{ path('app_site_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus"></i> Create New Site
                </a>
            </div>
        </div>
        <div class="card-body">
            {% if sites|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Domain</th>
                                <th>Locale</th>
                                <th>Hosting</th>
                                <th>Technology</th>
                                <th>Published At</th>
                                <th>Creator</th>
                                <th>Pages</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for site in sites %}
                                <tr>
                                    <td>
                                        {% if site.domain %}
                                            <a href="{{ site.domain }}" target="_blank">{{ site.domain }}</a>
                                        {% else %}
                                            <span class="text-muted">No domain</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.defaultLocale %}
                                            {{ site.defaultLocale }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.hosting %}
                                            {{ site.hosting }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.technology %}
                                            {{ site.technology }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.publishedAt %}
                                            {{ site.publishedAt|format_datetime }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if site.user and site.user.name %}
                                            {{ site.user.name }}
                                        {% else %}
                                            <span class="text-muted">Unknown</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {{ site.pageCount }}
                                    </td>
                                    <td>
                                        <span class="badge {{ site.statusBadgeClass }}">{{ site.status|default('Draft') }}</span>
                                    </td>
                                    <td>
                                        <a href="{{ path('app_site_show', {'id': site.id}) }}" class="btn btn-sm btn-primary" title="Manage">
                                            <i class="bi bi-gear"></i> Manage
                                        </a>
                                        <a href="{{ path('app_site_edit', {'id': site.id}) }}" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        {% if site.domain %}
                                            <a href="{{ site.domain }}" target="_blank" class="btn btn-sm btn-outline-success" title="Open Site">
                                                <i class="bi bi-box-arrow-up-right"></i> Open
                                            </a>
                                        {% endif %}
                                        <form method="POST" action="{{ path('app_site_delete', {'id': site.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this site?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ site.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <h5>No sites found</h5>
                    <p class="text-muted">Create your first site or adjust the filters above</p>
                    <a href="{{ path('app_site_new') }}" class="btn btn-primary mt-3">
                        <i class="bi bi-plus"></i> Create Site
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
