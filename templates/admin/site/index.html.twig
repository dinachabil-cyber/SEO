{% extends 'base.html.twig' %}

{% block title %}Sites{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">Sites</h1>

    {% for flashType, flashMessages in app.flashes %}
        {% for flashMessage in flashMessages %}
            <div class="alert alert-{{ flashType }} alert-dismissible fade show" role="alert">
                {{ flashMessage }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Create Site Form -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="card-title mb-0">Create New Site</h5>
        </div>

        <div class="card-body">
            {{ form_start(form) }}

            <!-- Row 1 -->
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.domain) }}
                    {{ form_widget(form.domain) }}
                    {{ form_errors(form.domain) }}
                </div>

                <div class="col-md-6 mb-3">
                    {{ form_label(form.hebergement) }}
                    {{ form_widget(form.hebergement) }}
                    {{ form_errors(form.hebergement) }}
                </div>
            </div>

            <!-- Row 2 -->
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.defaultLocale) }}
                    {{ form_widget(form.defaultLocale) }}
                    {{ form_errors(form.defaultLocale) }}
                </div>

                <div class="col-md-6 mb-3">
                    {{ form_label(form.isActive) }}
                    {{ form_widget(form.isActive) }}
                    {{ form_errors(form.isActive) }}
                </div>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Create Site
            </button>

            {{ form_end(form) }}
        </div>
    </div>

    <!-- Sites Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">All Sites</h5>
        </div>

        <div class="card-body">
            {% if sites|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped">

                        <thead>
                            <tr>
                                <th>Domain</th>
                                <th>Locale</th>
                                <th>Active</th>
                                <th>Hébergement</th>
                                <th>Created At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            {% for site in sites %}
                                <tr>

                                    <td>
                                        {% if site.domain %}
                                            <a href="{{ site.domain }}" target="_blank">
                                                {{ site.domain }}
                                            </a>
                                        {% else %}
                                            <span class="text-muted">No domain</span>
                                        {% endif %}
                                    </td>

                                    <td>{{ site.defaultLocale }}</td>

                                    <td>
                                        {% if site.isActive %}
                                            <span class="badge bg-success">Active</span>
                                        {% else %}
                                            <span class="badge bg-danger">Inactive</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if site.hebergement %}
                                            {{ site.hebergement }}
                                        {% else %}
                                            <span class="text-muted">No hébergement</span>
                                        {% endif %}
                                    </td>

                                    <td>{{ site.createdAt|format_datetime }}</td>

                                    <td>
                                        <a href="{{ path('app_site_show', {'id': site.id}) }}"
                                           class="btn btn-sm btn-primary">
                                           <i class="bi bi-gear"></i> Manage
                                        </a>

                                        <a href="{{ path('app_site_edit', {'id': site.id}) }}"
                                           class="btn btn-sm btn-outline-primary">
                                           <i class="bi bi-pencil"></i> Edit
                                        </a>

                                        <form method="POST"
                                              action="{{ path('app_site_delete', {'id': site.id}) }}"
                                              class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete this site?');">

                                            <input type="hidden"
                                                   name="_token"
                                                   value="{{ csrf_token('delete' ~ site.id) }}">

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>

                                        </form>
                                    </td>

                                </tr>
                            {% endfor %}
                        </tbody>

                    </table>
                </div>

            {% else %}

                <div class="text-center py-5">
                    <h5>No sites found</h5>
                    <p class="text-muted">
                        Create your first site using the form above
                    </p>
                </div>

            {% endif %}
        </div>
    </div>
</div>
{% endblock %}