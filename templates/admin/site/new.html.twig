{% extends 'base.html.twig' %}

{% block title %}Create New Site{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">Create New Site</h1>

    {% for flashType, flashMessages in app.flashes %}
        {% for flashMessage in flashMessages %}
            <div class="alert alert-{{ flashType }} alert-dismissible fade show" role="alert">
                {{ flashMessage }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">Site Information</h5>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_row(form.domain) }}
                {{ form_row(form.defaultLocale) }}
                {{ form_row(form.isActive) }}
                {{ form_row(form.hebergement) }}
                
                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Create Site
                    </button>
                    <a href="{{ path('app_site_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
