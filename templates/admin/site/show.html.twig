{% extends 'base.html.twig' %}

{% block title %}{{ site.name }} - Pages{% endblock %}

{% block body %}
<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ site.name }}</h1>
        <a href="{{ path('app_site_edit', {'id': site.id}) }}" class="btn btn-outline-primary">
            <i class="bi bi-pencil"></i> Edit Site
        </a>
    </div>

    {% for flashType, flashMessages in app.flashes %}
        {% for flashMessage in flashMessages %}
            <div class="alert alert-{{ flashType }} alert-dismissible fade show" role="alert">
                {{ flashMessage }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Site Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Domain:</strong> {% if site.domain %}{{ site.domain }}{% else %}No domain{% endif %}</p>
                    <p><strong>Locale:</strong> {{ site.defaultLocale }}</p>
                    <p><strong>Status:</strong> 
                        {% if site.isActive %}
                            <span class="badge badge-success">Active</span>
                        {% else %}
                            <span class="badge badge-danger">Inactive</span>
                        {% endif %}
                    </p>
                    <p><strong>Created:</strong> {{ site.createdAt|format_datetime }}</p>
                    <p><strong>Updated:</strong> {{ site.updatedAt|format_datetime }}</p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Page Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-sm-4">
                            <div class="stat-card">
                                <div class="stat-value">{{ totalPages }}</div>
                                <div class="stat-label">Total Pages</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="stat-card">
                                <div class="stat-value">{{ publishedPages }}</div>
                                <div class="stat-label">Published Pages</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="stat-card">
                                <div class="stat-value">{{ draftPages }}</div>
                                <div class="stat-label">Draft Pages</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Pages</h5>
            <a href="{{ path('app_page_new', {'site': site.id}) }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create Page
            </a>
        </div>
        <div class="card-body">
            {% if site.pages|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Slug</th>
                                <th>Meta Title</th>
                                <th>Publish Status</th>
                                <th>Created At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for page in site.pages %}
                                <tr>
                                    <td>{{ page.slug }}</td>
                                    <td>{{ page.metaTitle }}</td>
                                    <td>
                                        {% if page.isPublished %}
                                            <span class="badge badge-success">Published</span>
                                        {% else %}
                                            <span class="badge badge-warning">Draft</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ page.createdAt|format_datetime }}</td>
                                        <td>
                                            <a href="{{ path('app_page_builder', {'siteId': site.id, 'pageId': page.id}) }}" class="btn btn-sm btn-primary" title="Builder">
                                                <i class="bi bi-pencil-square"></i> Builder
                                            </a>
                                            <a href="{{ path('app_page_edit', {'site': site.id, 'pageId': page.id}) }}" class="btn btn-sm btn-outline-primary" title="Edit SEO">
                                                <i class="bi bi-pencil"></i> Edit SEO
                                            </a>
                                            <a href="{{ path('app_front_page', {'slug': page.slug}) }}" class="btn btn-sm btn-outline-success" title="Preview" target="_blank">
                                                <i class="bi bi-eye"></i> Preview
                                            </a>
                                            <form method="POST" action="{{ path('app_page_delete', {'site': site.id, 'pageId': page.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this page?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ page.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <h5>No pages found</h5>
                    <p class="text-muted">Create your first page to get started</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .stat-card {
            padding: 1rem;
            background-color: var(--surface-2);
            border-radius: var(--radius);
        }
        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }
        .stat-label {
            font-size: 0.875rem;
            color: var(--text-muted);
        }
    </style>
{% endblock %}
