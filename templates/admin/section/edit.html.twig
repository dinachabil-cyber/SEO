{% extends 'base.html.twig' %}

{% block title %}Edit Section{% endblock %}

{% block body %}
<div class="section-edit-container">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="card-title">Edit Section</h3>
                    </div>
                </div>
                
                <div class="card-body">
                    {% if section.referenceSection %}
                        <div class="alert alert-warning mb-4">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            This section is linked to the <strong>{{ section.referenceSection.name }}</strong> reference.
                            Editing this section will edit the reference, which affects all pages using it.
                            <a href="{{ path('app_section_detach', {siteId: site.id, pageId: page.id, sectionId: section.id}) }}" class="btn btn-sm btn-warning ms-2" onclick="return confirm('Are you sure you want to detach this section from the reference?');">
                                Detach from Reference
                            </a>
                        </div>
                    {% endif %}

                    {{ form_start(form, {attr: {class: 'needs-validation'}}) }}
                    <input type="hidden" name="referer" value="{{ app.request.headers.get('referer') }}">
                    
                    {% include 'admin/section/_form.html.twig' %}
                    
                    <div class="d-flex justify-content-end gap-2">
                        <a href="{{ app.request.headers.get('referer') ?? path('app_page_builder', {siteId: site.id, pageId: page.id}) }}" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i> Save Changes
                        </button>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
</div>
{% endblock %}
