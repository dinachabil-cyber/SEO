{% extends 'base.html.twig' %}

{% block title %}Add Section{% endblock %}

{% block body %}
<div class="section-edit-container">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="card-title">Add Section</h3>
                        <a href="javascript:history.back()" class="back-btn" aria-label="Go back">
                            ←
                        </a>
                    </div>
                </div>
                
                <div class="card-body">
                    {{ form_start(form, {attr: {class: 'needs-validation'}}) }}
                    <input type="hidden" name="referer" value="{{ app.request.headers.get('referer') }}">
                    
                    {% include 'admin/section/_form.html.twig' %}
                    
                    <div class="d-flex justify-content-end gap-2">
                        <a href="{{ app.request.headers.get('referer') ?? path('app_page_builder', {siteId: site.id, pageId: page.id}) }}" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-1"></i> Add Section
                        </button>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
</div>
{% endblock %}
