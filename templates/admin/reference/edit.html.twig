{% extends 'base.html.twig' %}

{% block title %}Edit Reference Section{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">Edit Reference Section</h1>

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">Edit "{{ reference_section.name }}"</h5>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
            
            {{ form_row(form.name) }}
            
            {{ include('admin/section/_form.html.twig') }}
            
            <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="{{ path('app_reference_section_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Update Reference Section
                </button>
            </div>
            
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
