{% extends 'base.html.twig' %}

{% block title %}Reference Sections{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">Reference Sections</h1>

    {% for flashType, flashMessages in app.flashes %}
        {% for flashMessage in flashMessages %}
            <div class="alert alert-{{ flashType }} alert-dismissible fade show" role="alert">
                {{ flashMessage }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <a href="{{ path('app_reference_section_new') }}" class="btn btn-primary mb-4">
        <i class="bi bi-plus"></i> Create New Reference Section
    </a>

    {% if reference_sections|length > 0 %}
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">All Reference Sections</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Created At</th>
                                <th>Updated At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for section in reference_sections %}
                                <tr>
                                    <td>{{ section.name }}</td>
                                    <td>
                                        <span class="badge bg-primary">{{ section.type }}</span>
                                    </td>
                                    <td>{{ section.createdAt|format_datetime }}</td>
                                    <td>{{ section.updatedAt|format_datetime }}</td>
                                    <td>
                                        <a href="{{ path('app_reference_section_show', {'id': section.id}) }}" class="btn btn-sm btn-primary" title="Show">
                                            <i class="bi bi-eye"></i> Show
                                        </a>
                                        <a href="{{ path('app_reference_section_edit', {'id': section.id}) }}" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form method="POST" action="{{ path('app_reference_section_delete', {'id': section.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this reference section?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ section.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% else %}
        <div class="text-center py-5">
            <h5>No reference sections found</h5>
            <p class="text-muted">Create your first reference section using the button above</p>
        </div>
    {% endif %}
</div>
{% endblock %}
