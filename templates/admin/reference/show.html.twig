{% extends 'base.html.twig' %}

{% block title %}{{ reference_section.name }}{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">{{ reference_section.name }}</h1>

    <div class="d-flex justify-content-end gap-2 mb-4">
        <a href="{{ path('app_reference_section_edit', {'id': reference_section.id}) }}" class="btn btn-outline-primary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a href="{{ path('app_reference_section_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">Section Details</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">{{ reference_section.id }}</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">{{ reference_section.name }}</dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-primary">{{ reference_section.type }}</span>
                </dd>

                <dt class="col-sm-3">Created At</dt>
                <dd class="col-sm-9">{{ reference_section.createdAt|format_datetime }}</dd>

                <dt class="col-sm-3">Updated At</dt>
                <dd class="col-sm-9">{{ reference_section.updatedAt|format_datetime }}</dd>

                <dt class="col-sm-3">Data</dt>
                <dd class="col-sm-9">
                    <pre>{{ reference_section.data|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                </dd>
            </dl>
        </div>
    </div>
</div>
{% endblock %}
