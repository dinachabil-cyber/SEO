{% extends 'base.html.twig' %}

{% block title %}Page Builder - {{ page.metaTitle }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="card-title">Page Builder - {{ page.metaTitle }}</h3>
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_page_preview', {siteId: page.site.id, pageId: page.id}) }}" class="btn btn-outline-primary" target="_blank">
                                <i class="bi bi-eye me-1"></i> Preview Page
                            </a>
                            <a href="{{ path('app_page_edit', {site: page.site.id, pageId: page.id}) }}" class="btn btn-outline-secondary">
                                <i class="bi bi-pencil-square me-1"></i> Page Settings
                            </a>
                            <a href="{{ path('app_site_show', {id: page.site.id}) }}" class="btn btn-outline-dark">
                                <i class="bi bi-arrow-left me-1"></i> Back to Site
                            </a>
                        </div>
                    </div>
                </div>
                
                <div class="card-body">
                    {# Page Info #}
                    <div class="mb-4 p-3 bg-light rounded">
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="fw-bold">Page Details:</h6>
                                <p class="mb-1"><strong>Slug:</strong> {{ page.slug }}</p>
                                <p class="mb-1"><strong>Title:</strong> {{ page.metaTitle }}</p>
                                <p class="mb-1"><strong>Status:</strong> 
                                    <span class="badge {% if page.isPublished %}bg-success{% else %}bg-warning{% endif %}">
                                        {% if page.isPublished %}Published{% else %}Draft{% endif %}
                                    </span>
                                </p>
                                    <p class="mb-1"><strong>H1:</strong> {{ page.h1 ?: '-' }}</p>

                            </div>
                           <div class="col-md-6">
    <h6 class="fw-bold mb-3">SEO: </h6> <p class="mb-1"><strong>Google Ads:</strong> {{ page.googleAds ?: '-' }}</p>
        <p class="mb-1"><strong>Google Analytics:</strong> {{ page.googleAnalytics ?: '-' }}</p>
        <p class="mb-1"><strong>Google Tag Manager:</strong> {{ page.googleTagManager ?: '-' }}</p><div class="mt-3 pt-3 border-top">
       
    </div>

    <p class="mb-1"><strong>Meta Title:</strong> {{ page.metaTitle ?: '-' }}</p>
    <p class="mb-1"><strong>Meta Description:</strong> {{ page.metaDescription ?: '-' }}</p>
    <p class="mb-1"><strong>Meta Keywords:</strong> {{ page.metaKeywords ?: '-' }}</p>

    
</div>
                        </div>
                    </div>

                    {# Action Buttons #}
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="mb-0">Sections</h4>
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_section_new', {siteId: page.site.id, pageId: page.id}) }}" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-1"></i> Add Section
                            </a>
                            <a href="{{ path('app_section_import_reference', {siteId: page.site.id, pageId: page.id}) }}" class="btn btn-outline-primary">
                                <i class="bi bi-bookmarks me-1"></i> Import Reference
                            </a>
                        </div>
                    </div>

                    {# Sections List #}
                    <div class="sections-list">
                        {% if page.sections is empty %}
                            <div class="text-center py-10">
                                <i class="bi bi-file-earmark-text display-1 text-muted mb-3"></i>
                                <h4 class="mb-2">No Sections Yet</h4>
                                <p class="text-muted mb-4">Start building your page by adding sections</p>
                                <a href="{{ path('app_section_new', {siteId: page.site.id, pageId: page.id}) }}" class="btn btn-primary">
                                    <i class="bi bi-plus-circle me-1"></i> Add First Section
                                </a>
                            </div>
                        {% else %}
                            {% for section in page.sections %}
                                <div class="card mb-3 section-card shadow-sm hover-shadow-lg">
                                    <div class="card-header d-flex justify-content-between align-items-center bg-white border-bottom">
                                        <div class="d-flex align-items-center gap-2">
                                          {% if section.type == 'header' %}
    <i class="bi bi-layout-text-window fs-4 text-primary"></i>
{% elseif section.type == 'hero' %}
    <i class="bi bi-lightning-fill fs-4 text-warning"></i>
{% elseif section.type == 'hero_split' %}
    <i class="bi bi-columns-gap fs-4 text-warning"></i>
{% elseif section.type == 'body' %}
    <i class="bi bi-file-earmark-text fs-4 text-secondary"></i>
{% elseif section.type == 'image' %}
    <i class="bi bi-card-image fs-4 text-info"></i>
{% elseif section.type == 'cards' %}
    <i class="bi bi-grid fs-4 text-success"></i>
{% elseif section.type == 'faq' %}
    <i class="bi bi-question-circle fs-4 text-danger"></i>
{% elseif section.type == 'form' %}
    <i class="bi bi-ui-checks-grid fs-4 text-accent"></i>
{% elseif section.type == 'cta' %}
    <i class="bi bi-megaphone fs-4 text-purple"></i>
{% elseif section.type == 'footer' %}
    <i class="bi bi-layout-text-sidebar-reverse fs-4 text-dark"></i>
{% endif %}
                                            <span class="badge bg-info text-white">{{ section.type|capitalize }}</span>
                                        </div>
                                        <div class="d-flex gap-1">
                                            {% if section.referenceSection %}
                                                <span class="badge bg-primary text-white me-2">Linked to Reference</span>
                                                <a href="{{ path('app_section_detach', {siteId: page.site.id, pageId: page.id, sectionId: section.id}) }}" class="btn btn-sm btn-outline-warning">
                                                    <i class="bi bi-unlink"></i> Detach
                                                </a>
                                            {% else %}
                                                <a href="{{ path('app_section_edit', {siteId: page.site.id, pageId: page.id, sectionId: section.id}) }}" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </a>
                                                <a href="{{ path('app_section_save_reference', {siteId: page.site.id, pageId: page.id, sectionId: section.id}) }}" class="btn btn-sm btn-outline-info">
                                                    <i class="bi bi-bookmark"></i> Save as Reference
                                                </a>
                                            {% endif %}
                                            <form method="POST" action="{{ path('app_section_delete', {siteId: page.site.id, pageId: page.id, sectionId: section.id}) }}" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this section?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ section.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                            {% if section.type not in ['header', 'footer'] and loop.index0 > 0 %}
                                                <form method="POST" action="{{ path('app_section_up', {siteId: page.site.id, pageId: page.id, sectionId: section.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ section.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                        <i class="bi bi-arrow-up"></i> Up
                                                    </button>
                                                </form>
                                            {% else %}
                                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled>
                                                    <i class="bi bi-arrow-up"></i> Up
                                                </button>
                                            {% endif %}
                                            {% if section.type not in ['header', 'footer'] and loop.index < page.sections|length %}
                                                <form method="POST" action="{{ path('app_section_down', {siteId: page.site.id, pageId: page.id, sectionId: section.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ section.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                        <i class="bi bi-arrow-down"></i> Down
                                                    </button>
                                                </form>
                                            {% else %}
                                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled>
                                                    <i class="bi bi-arrow-down"></i> Down
                                                </button>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="card-body">
                                    {% set data = section.effectiveData %}

{% if section.type == 'header' %}
    <p><strong>Brand:</strong> {{ data.brandText ?? '' }}</p>
    <p><strong>Menu items:</strong> {{ (data.menuItems ?? [])|length }}</p>
    {% if data.ctaText is defined and data.ctaText %}
        <p><strong>CTA:</strong> {{ data.ctaText }}</p>
    {% endif %}

{% elseif section.type == 'hero' %}
    <p><strong>Title:</strong> {{ data.title ?? '' }}</p>
    {% if data.subtitle is defined and data.subtitle %}
        <p><strong>Subtitle:</strong> {{ data.subtitle|slice(0, 80) }}...</p>
    {% endif %}
    {% if data.ctaText is defined and data.ctaText %}
        <p><strong>CTA:</strong> {{ data.ctaText }}</p>
    {% endif %}

{% elseif section.type == 'hero_split' %}
    <p><strong>Hero Title:</strong> {{ data.title ?? '' }}</p>
    <p><strong>Image:</strong> {{ data.imageUrl ? 'Yes' : 'No' }}</p>
    <p><strong>Form Title:</strong> {{ data.form.title ?? data.formTitle ?? '' }}</p>
    <p><strong>Form Fields:</strong> {{ (data.form.fields ?? data.formFields ?? [])|length }}</p>
    <p><strong>Layout:</strong> {{ data.style.layout ?? 'image-left-form-right' }}</p>

{% elseif section.type == 'body' %}
    {% if data.title is defined and data.title %}
        <p><strong>Title:</strong> {{ data.title }}</p>
    {% endif %}
    <p><strong>Content:</strong> {{ (data.content ?? '')|striptags|slice(0, 100) }}...</p>

{% elseif section.type == 'image' %}
    <p><strong>Image:</strong> {{ data.imageUrl ?? '' }}</p>
    <p><strong>Alt:</strong> {{ data.alt ?? '' }}</p>

{% elseif section.type == 'cards' %}
    {% if data.sectionTitle %}
        <p><strong>Title:</strong> {{ data.sectionTitle }}</p>
    {% endif %}
    <p><strong>Cards:</strong> {{ (data.cards ?? [])|length }} card(s)</p>
    <p><strong>Columns:</strong> {{ data.style.columns ?? 3 }}</p>

{% elseif section.type == 'faq' %}
    {% if data.sectionTitle %}
        <p><strong>Title:</strong> {{ data.sectionTitle }}</p>
    {% endif %}
    <p><strong>Items:</strong> {{ (data.items ?? [])|length }} FAQ item(s)</p>

{% elseif section.type == 'form' %}
    <p><strong>Title:</strong> {{ data.title ?? '' }}</p>
    <p><strong>Fields:</strong> {{ (data.fields ?? [])|length }} field(s)</p>
    <p><strong>Submit:</strong> {{ data.submitText ?? '' }}</p>

{% elseif section.type == 'cta' %}
    <p><strong>Title:</strong> {{ data.title ?? '' }}</p>
    {% if data.text %}
        <p><strong>Text:</strong> {{ data.text|slice(0, 100) }}...</p>
    {% endif %}
    <p><strong>Button:</strong> {{ data.buttonText ?? '' }}</p>

{% elseif section.type == 'footer' %}
    <p><strong>Brand:</strong> {{ data.brandName ?? '' }}</p>
    <p><strong>Useful Links:</strong> {{ (data.usefulLinks ?? [])|length }}</p>
    {% if data.phone %}
        <p><strong>Phone:</strong> {{ data.phone }}</p>
    {% endif %}
    {% if data.email %}
        <p><strong>Email:</strong> {{ data.email }}</p>
    {% endif %}
{% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
