{% extends 'base.html.twig' %}

{% block title %}Site Dashboard{% endblock %}

{% block body %}
    <div class="container">
        <h1>Site Dashboard - {{ site.name }}</h1>
        
        <div class="site-info">
            <p><strong>Domain:</strong> {{ site.domain }}</p>
            <p><strong>Default Locale:</strong> {{ site.defaultLocale }}</p>
            <p><strong>Status:</strong> {{ site.isActive ? 'Active' : 'Inactive' }}</p>
        </div>

        <h2>Pages</h2>
        <a href="{{ path('app_admin_page_create', {'id': site.id}) }}" class="btn btn-primary">Create Page</a>
        
        <table class="table">
            <thead>
                <tr>
                    <th>Slug</th>
                    <th>Meta Title</th>
                    <th>Published</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for page in site.pages %}
                    <tr>
                        <td>{{ page.slug }}</td>
                        <td>{{ page.metaTitle }}</td>
                        <td>{{ page.isPublished ? 'Yes' : 'No' }}</td>
                        <td>
                            <a href="{{ path('app_admin_page_builder', {'pageId': page.id}) }}" class="btn btn-sm btn-secondary">Builder</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
