{% extends 'base.html.twig' %}

{% block title %}{{ page.metaTitle ? page.metaTitle : page.h1 ? page.h1 : 'Page' }}{% endblock %}

{% block body %}
    <div class="container">
        {% for section in sections %}
            {% if section.type == 'header' %}
                <header class="header">
                    <div class="logo">{{ section.data.logoText }}</div>
                    {% if section.data.menu %}
                        <nav class="nav">
                            {% for item in section.data.menu %}
                                <a href="{{ path('app_front_page_show', {'slug': item.targetSlug}) }}">{{ item.label }}</a>
                            {% endfor %}
                        </nav>
                    {% endif %}
                </header>
            {% elseif section.type == 'body' %}
                <section class="body">
                    {{ section.data.html | raw }}
                </section>
            {% elseif section.type == 'image' %}
                <section class="image">
                    <img src="{{ section.data.src }}" alt="{{ section.data.alt }}">
                </section>
            {% elseif section.type == 'cards' %}
                <section class="cards">
                    <div class="cards-grid">
                        {% for card in section.data.cards %}
                            <div class="card">
                                {% if card.image %}
                                    <img src="{{ card.image }}" alt="{{ card.title }}">
                                {% endif %}
                                <h3>{{ card.title }}</h3>
                                <p>{{ card.text }}</p>
                                <a href="{{ path('app_front_page_show', {'slug': card.targetSlug}) }}" class="btn btn-primary">{{ card.buttonText }}</a>
                            </div>
                        {% endfor %}
                    </div>
                </section>
            {% elseif section.type == 'form' %}
                <section class="form">
                    <h2>{{ section.data.title }}</h2>
                    <form>
                        {% for field in section.data.fields %}
                            <div class="form-group">
                                <label for="{{ field.name }}">{{ field.label }}</label>
                                <input type="{{ field.type }}" id="{{ field.name }}" name="{{ field.name }}" {% if field.required %}required{% endif %} class="form-control">
                            </div>
                        {% endfor %}
                        <button type="submit" class="btn btn-primary">{{ section.data.submitText }}</button>
                    </form>
                </section>
            {% elseif section.type == 'footer' %}
                <footer class="footer">
                    <p>{{ section.data.text }}</p>
                    {% if section.data.links %}
                        <nav class="footer-nav">
                            {% for item in section.data.links %}
                                <a href="{{ path('app_front_page_show', {'slug': item.targetSlug}) }}">{{ item.label }}</a>
                            {% endfor %}
                        </nav>
                    {% endif %}
                </footer>
            {% endif %}
        {% endfor %}
    </div>
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
{% endblock %}

{% block javascripts %}
    <script>
        // Add any front-end JavaScript here
    </script>
{% endblock %}
