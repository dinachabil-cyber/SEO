<section class="section {% if data.style is defined and data.style is not null and data.style.background %} {% else %}bg-white{% endif %}" 
         {% if data.style is defined and data.style is not null and data.style.background %}style="background-color: {{ data.style.background }};{% endif %}">
    <div class="container">
        {% if data.title %}
            <div class="text-center mb-5">
                <h2{% if data.style is defined and data.style is not null and data.style.textColor %} style="color: {{ data.style.textColor }};"{% endif %}>{{ data.title }}</h2>
            </div>
        {% endif %}
        
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="lead-form">
                    <form method="POST" action="{{ path('app_contact') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('contact_form') }}">
                        
                        {% if data.fields is defined %}
                            <div class="row g-3">
                                {% for field in data.fields %}
                                    <div class="{% if field.width == 'half' %}col-md-6{% else %}col-12{% endif %}">
                                        {% if field.type == 'text' or field.type == 'email' or field.type == 'tel' %}
                                            <div class="mb-3">
                                                {% if field.label %}
                                                    <label class="form-label" for="{{ field.name }}">{{ field.label }}{% if field.required %} <span class="text-danger">*</span>{% endif %}</label>
                                                {% endif %}
                                                <input type="{{ field.type }}" 
                                                       class="form-control" 
                                                       id="{{ field.name }}" 
                                                       name="{{ field.name }}" 
                                                       placeholder="{{ field.placeholder|default('') }}" 
                                                       {% if field.required %}required{% endif %}>
                                            </div>
                                        {% elseif field.type == 'textarea' %}
                                            <div class="mb-3">
                                                {% if field.label %}
                                                    <label class="form-label" for="{{ field.name }}">{{ field.label }}{% if field.required %} <span class="text-danger">*</span>{% endif %}</label>
                                                {% endif %}
                                                <textarea class="form-control" 
                                                          id="{{ field.name }}" 
                                                          name="{{ field.name }}" 
                                                          rows="4" 
                                                          placeholder="{{ field.placeholder|default('') }}" 
                                                          {% if field.required %}required{% endif %}></textarea>
                                            </div>
                                        {% elseif field.type == 'select' %}
                                            <div class="mb-3">
                                                {% if field.label %}
                                                    <label class="form-label" for="{{ field.name }}">{{ field.label }}{% if field.required %} <span class="text-danger">*</span>{% endif %}</label>
                                                {% endif %}
                                                <select class="form-control" 
                                                        id="{{ field.name }}" 
                                                        name="{{ field.name }}" 
                                                        {% if field.required %}required{% endif %}>
                                                    {% if field.placeholder %}
                                                        <option value="" disabled selected>{{ field.placeholder }}</option>
                                                    {% endif %}
                                                    {% set options = field.options|split('\n') %}
                                                    {% for option in options %}
                                                        {% set trimmedOption = option|trim %}
                                                        {% if trimmedOption %}
                                                            <option value="{{ trimmedOption }}">{{ trimmedOption }}</option>
                                                        {% endif %}
                                                    {% endfor %}
                                                </select>
                                            </div>
                                        {% elseif field.type == 'checkbox' %}
                                            <div class="form-check mb-3">
                                                <input type="checkbox" 
                                                       class="form-check-input" 
                                                       id="{{ field.name }}" 
                                                       name="{{ field.name }}" 
                                                       {% if field.required %}required{% endif %}>
                                                <label class="form-check-label" for="{{ field.name }}">
                                                    {{ field.label }}{% if field.required %} <span class="text-danger">*</span>{% endif %}
                                                </label>
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                        
                        <button type="submit" class="btn {% if data.style is defined and data.style is not null and data.style.buttonColor %}btn-{{ data.style.buttonColor }}{% else %}btn-primary{% endif %} w-100"
                                {% if data.style is defined and data.style is not null and data.style.buttonColor == 'custom' and data.style.buttonCustomColor %}style="background-color: {{ data.style.buttonCustomColor }}; border-color: {{ data.style.buttonCustomColor }};"{% endif %}>
                            {{ data.submitText|default('Submit') }}
                        </button>
                        
                        {% if data.successMessage %}
                            <div id="successMessage" class="alert alert-success mt-3 d-none">
                                {{ data.successMessage }}
                            </div>
                        {% endif %}
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
