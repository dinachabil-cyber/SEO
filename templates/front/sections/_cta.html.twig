<section class="cta-band {% if data.backgroundColor %}custom-bg{% endif %}" {% if data.backgroundColor %}style="background-color: {{ data.backgroundColor }}; {% if data.paddingTop %}padding-top: {{ data.paddingTop }}px;{% endif %} {% if data.paddingBottom %}padding-bottom: {{ data.paddingBottom }}px;{% endif %} {% if data.marginTop %}margin-top: {{ data.marginTop }}px;{% endif %} {% if data.marginBottom %}margin-bottom: {{ data.marginBottom }}px;{% endif %}"{% endif %}>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 {% if data.textAlignment %}text-{{ data.textAlignment }}{% else %}text-center{% endif %}" {% if data.textColor %}style="color: {{ data.textColor }}"{% endif %}>
                <h2 class="mb-4" {% if data.titleColor %}style="color: {{ data.titleColor }}"{% endif %}>{{ data.title }}</h2>
                {% if data.text %}
                    <p class="mb-5">{{ data.text }}</p>
                {% endif %}
                <a href="{{ data.buttonUrl }}" class="btn btn-{% if data.buttonStyle %}{{ data.buttonStyle }}{% else %}light{% endif %} btn-lg" {% if data.buttonBackgroundColor %}style="background-color: {{ data.buttonBackgroundColor }}; {% if data.buttonTextColor %}color: {{ data.buttonTextColor }};{% endif %} {% if data.buttonBorderColor %}border-color: {{ data.buttonBorderColor }};{% endif %} {% if data.buttonBorderRadius %}border-radius: {{ data.buttonBorderRadius }}px;{% endif %}"{% endif %}>
                    {{ data.buttonText }}
                </a>
            </div>
        </div>
    </div>
</section>
