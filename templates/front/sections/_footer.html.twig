<footer class="site-footer py-5 {% if not (data.style.background) %}
            {% if data.style.variant == 'dark' %}bg-dark text-white{% else %}bg-light text-dark{% endif %}
        {% endif %}" 
        style="{% if data.style.background %}background-color: {{ data.style.background }};{% endif %}{% if data.style.textColor %} color: {{ data.style.textColor }};{% else %}{% if not (data.style.background) %}
            {% if data.style.variant == 'dark' %} color: #ffffff;{% else %} color: #000000;{% endif %}
        {% else %}
            color: #000000;
        {% endif %}{% endif %}">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                {% if data.brandName is defined and data.brandName %}
                    <h4 class="mb-3">{{ data.brandName }}</h4>
                {% endif %}

                {% if data.description is defined and data.description %}
                    <p{% if data.style is defined and data.style is not null and data.style.background %} class="footer-text-muted"{% else %} class="text-white-50"{% endif %}>{{ data.description|nl2br }}</p>
                {% elseif data.text is defined and data.text %}
                    <p{% if data.style is defined and data.style is not null and data.style.background %} class="footer-text-muted"{% else %} class="text-white-50"{% endif %}>{{ data.text|nl2br }}</p>
                {% endif %}
            </div>

            <div class="col-md-4">
                {% if data.usefulLinks is defined and data.usefulLinks|length > 0 %}
                    <h5 class="mb-3">Liens utiles</h5>
                    <ul class="list-unstyled">
                        {% for link in data.usefulLinks %}
                            <li class="mb-2">
                                <a href="{{ link.url }}"{% if data.style is defined and data.style is not null and data.style.background %} class="footer-link text-decoration-none"{% else %} class="text-white-50 text-decoration-none"{% endif %}>
                                    {{ link.label }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>

                {% elseif data.links is defined and data.links %}
                    <h5 class="mb-3">Liens utiles</h5>
                    <ul class="list-unstyled">
                        {% set links = data.links|split('\n') %}
                        {% for link in links %}
                            {% if link %}
                                {% set parts = link|split('|') %}
                                {% if parts|length == 2 %}
                                    <li class="mb-2">
                                        <a href="{{ parts[1] }}"{% if data.style is defined and data.style is not null and data.style.background %} class="footer-link text-decoration-none"{% else %} class="text-white-50 text-decoration-none"{% endif %}>
                                            {{ parts[0] }}
                                        </a>
                                    </li>
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>

            <div class="col-md-4">
                <h5 class="mb-3">Contact</h5>

                {% if data.address is defined and data.address %}
                    <p{% if data.style is defined and data.style is not null and data.style.background %} class="footer-text-muted mb-2"{% else %} class="text-white-50 mb-2"{% endif %}>{{ data.address|nl2br }}</p>
                {% endif %}

                {% if data.phone is defined and data.phone %}
                    <p class="mb-2">
                        <a href="tel:{{ data.phone }}"{% if data.style is defined and data.style is not null and data.style.background %} class="footer-link text-decoration-none"{% else %} class="text-white-50 text-decoration-none"{% endif %}>
                            {{ data.phone }}
                        </a>
                    </p>
                {% endif %}

                {% if data.email is defined and data.email %}
                    <p class="mb-0">
                        <a href="mailto:{{ data.email }}"{% if data.style is defined and data.style is not null and data.style.background %} class="footer-link text-decoration-none"{% else %} class="text-white-50 text-decoration-none"{% endif %}>
                            {{ data.email }}
                        </a>
                    </p>
                {% endif %}
            </div>
        </div>

        <hr class="my-4 {% if data.style is defined and data.style is not null and data.style.background %}footer-hr{% else %}border-secondary{% endif %}">

        <div class="text-center small{% if data.style is defined and data.style is not null and data.style.background %} footer-text-muted{% else %} text-white-50{% endif %}">
            {% if data.copyright is defined and data.copyright %}
                {{ data.copyright }}
            {% else %}
                © {{ "now"|date("Y") }} All rights reserved.
            {% endif %}
        </div>
    </div>
</footer>