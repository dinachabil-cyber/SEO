{% extends 'base.html.twig' %}

{% block title %}Page{% endblock %}

{% block body %}
    <h1>Page</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ page.id }}</td>
            </tr>
            <tr>
                <th>Url</th>
                <td>{{ page.url }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ page.title }}</td>
            </tr>
            <tr>
                <th>H1</th>
                <td>{{ page.h1 }}</td>
            </tr>
            <tr>
                <th>Target Keywords</th>
                <td>{{ page.targetKeywords }}</td>
            </tr>
            <tr>
                <th>Meta Description</th>
                <td>{{ page.metaDescription }}</td>
            </tr>
            <tr>
                <th>Internal Links</th>
                <td>{{ page.internalLinks }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_page_index') }}">back to list</a>

    <a href="{{ path('app_page_edit', {'id': page.id}) }}">edit</a>

    {{ include('page/_delete_form.html.twig') }}
{% endblock %}
